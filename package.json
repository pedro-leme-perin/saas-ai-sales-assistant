{
  "name": "saas-ai-sales-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade AI-powered Sales Assistant SaaS Platform — Monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @saas/backend run start:dev",
    "dev:frontend": "pnpm --filter @saas/frontend run dev",
    "build": "pnpm -r run build",
    "build:backend": "pnpm --filter @saas/backend run build",
    "build:frontend": "pnpm --filter @saas/frontend run build",
    "lint": "pnpm -r run lint",
    "lint:check": "pnpm -r run lint:check",
    "type-check": "pnpm -r run type-check",
    "test": "pnpm --filter @saas/backend run test",
    "test:unit": "pnpm --filter @saas/backend run test:unit",
    "test:integration": "pnpm --filter @saas/backend run test:integration",
    "test:e2e": "pnpm --filter @saas/frontend exec playwright test",
    "format": "pnpm -r run format",
    "prisma:generate": "pnpm --filter @saas/backend run prisma:generate",
    "prisma:migrate": "pnpm --filter @saas/backend run prisma:migrate",
    "prisma:studio": "pnpm --filter @saas/backend run prisma:studio",
    "prisma:seed": "pnpm --filter @saas/backend run prisma:seed",
    "clean": "pnpm -r exec rm -rf node_modules dist .next coverage .turbo",
    "prepare": "husky || true",
    "changelog:preview": "conventional-changelog -p angular -i CHANGELOG.md -s -o /dev/stdout",
    "changelog:generate": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:full": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "conventional-changelog-cli": "^5.0.0"
  },
  "lint-staged": {
    "apps/backend/{src,test}/**/*.{ts,js}": [
      "prettier --write --ignore-unknown",
      "node apps/backend/node_modules/eslint/bin/eslint.js --resolve-plugins-relative-to apps/backend --fix --max-warnings 0 --no-error-on-unmatched-pattern"
    ],
    "apps/frontend/src/**/*.{ts,tsx,js,jsx}": [
      "prettier --write --ignore-unknown",
      "node apps/frontend/node_modules/eslint/bin/eslint.js --config apps/frontend/eslint.config.mjs --fix --max-warnings 0 --no-error-on-unmatched-pattern"
    ],
    "packages/shared/src/**/*.{ts,js}": [
      "prettier --write --ignore-unknown"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ],
    "**/*.{json,md,yml,yaml,css,scss}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "pnpm": {
    "overrides": {
      "@clerk/nextjs": "^6.39.2",
      "@clerk/shared@2": "~2.22.1",
      "@clerk/shared@3": "~3.47.4",
      "follow-redirects": "~1.16.0",
      "lodash": "^4.18.0",
      "multer": "~2.1.1",
      "protobufjs": ">=7.5.5"
    }
  }
}
