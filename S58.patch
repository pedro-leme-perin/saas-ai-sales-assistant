+
+ALTER TABLE "config_snapshots" ADD CONSTRAINT "config_snapshots_company_id_fkey"
+  FOREIGN KEY ("company_id") REFERENCES "companies"("id") ON DELETE CASCADE ON UPDATE CASCADE;
