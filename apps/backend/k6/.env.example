# k6 Environment Configuration Template
# Copy to .env and source before running: `source .env && k6 run baseline-test.js`

# Backend URL (production vs staging vs local)
# Production:
BASE_URL=https://api.theiadvisor.com

# Staging:
# BASE_URL=https://backend-staging.railway.app

# Local:
# BASE_URL=http://localhost:3001

# Clerk JWT token for authenticated endpoints
# How to obtain:
#   1. Sign in to https://theiadvisor.com
#   2. Open DevTools → Console
#   3. await window.Clerk.session.getToken()
#   4. Copy the token (valid ~60s)
# Prefix with "Bearer "
AUTH_TOKEN="Bearer eyJ..."

# Company ID (multi-tenant key) — optional, used in some tests
COMPANY_ID=
