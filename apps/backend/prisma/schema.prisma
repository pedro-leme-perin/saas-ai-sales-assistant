// =============================================
// 📦 PRISMA SCHEMA - TheIAdvisor
// =============================================
// Enterprise-grade database schema
// Following best practices from:
// - Designing Data-Intensive Applications (Kleppmann)
// - Clean Architecture (Robert Martin)
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// 🏢 MULTI-TENANT: COMPANY (Tenant Root)
// =============================================

model Company {
  id               String    @id @default(uuid())
  name             String
  slug             String?    @unique
  plan             Plan      @default(STARTER)
  
  // Stripe Integration
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  billingEmail     String?   @map("billing_email")
  
  // Company Details
  logoUrl          String?   @map("logo_url")
  website          String?
  industry         String?
  size             CompanySize?
  timezone         String    @default("America/Sao_Paulo")
  
  // Feature Limits (based on plan)
  maxUsers         Int       @default(5) @map("max_users")
  maxCallsPerMonth Int       @default(100) @map("max_calls_per_month")
  maxChatsPerMonth Int       @default(50) @map("max_chats_per_month")
  
  // Settings (JSON for flexibility)
  settings         Json      @default("{}")
  
  // WhatsApp Business API
  whatsappPhoneNumberId  String?  @map("whatsapp_phone_number_id")
  whatsappAccessToken    String?  @map("whatsapp_access_token")
  whatsappVerifyToken    String?  @map("whatsapp_verify_token")

  // Status
  isActive         Boolean   @default(true) @map("is_active")
  deletedAt        DateTime? @map("deleted_at")
  
  // Timestamps
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  users            User[]
  calls            Call[]
  whatsappChats    WhatsappChat[]
  subscriptions    Subscription[]
  invoices         Invoice[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  coachingReports  CoachingReport[]
  teamGoals        TeamGoal[]
  callSummaries    CallSummary[]
  webhookEndpoints WebhookEndpoint[]
  replyTemplates   ReplyTemplate[]
  conversationTags ConversationTag[]
  notificationPrefs NotificationPreference[]
  savedFilters     SavedFilter[]
  backgroundJobs   BackgroundJob[]
  slaPolicies      SlaPolicy[]
  contacts         Contact[]
  csatConfigs      CsatSurveyConfig[]
  csatResponses    CsatResponse[]
  scheduledExports ScheduledExport[]
  retentionPolicies RetentionPolicy[]
  apiRequestLogs   ApiRequestLog[]

  @@index([slug])
  @@index([stripeCustomerId])
  @@index([isActive])
  @@map("companies")
}

// =============================================
// 👤 USER
// =============================================

model User {
  id                      String     @id @default(uuid())
  
  // Authentication (Clerk)
  clerkId                 String     @unique @map("clerk_id")
  email                   String
  
  // Profile
  name                    String
  avatarUrl               String?    @map("avatar_url")
  phone                   String?
  
  // Role & Permissions
  role                    UserRole   @default(VENDOR)
  permissions             String[]   @default([])
  
  // Status
  status                  UserStatus @default(ACTIVE)
  isActive                Boolean    @default(true) @map("is_active")
  lastActiveAt            DateTime?  @map("last_active_at")
  
  // Preferences
  notificationPreferences Json?      @map("notification_preferences")
  uiPreferences           Json?      @map("ui_preferences")
  
  // Soft Delete
  deletedAt               DateTime?  @map("deleted_at")

  // LGPD — Scheduled Hard Deletion (Art. 16, III — eliminação)
  scheduledDeletionAt     DateTime?  @map("scheduled_deletion_at")
  deletionReason          String?    @map("deletion_reason")

  // Tenant Relationship
  companyId               String     @map("company_id")
  company                 Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")

  // Relations
  calls                   Call[]
  whatsappChats           WhatsappChat[]
  aiSuggestions           AISuggestion[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  coachingReports         CoachingReport[]
  teamGoalsCreated        TeamGoal[]        @relation("TeamGoalCreator")
  teamGoalsAssigned       TeamGoal[]        @relation("TeamGoalAssignee")
  webhookEndpointsCreated WebhookEndpoint[] @relation("WebhookEndpointCreator")
  replyTemplatesCreated   ReplyTemplate[]   @relation("ReplyTemplateCreator")
  conversationTagsCreated ConversationTag[] @relation("ConversationTagCreator")
  apiKeysCreated          ApiKey[]          @relation("ApiKeyCreator")
  notificationPrefs       NotificationPreference[]
  savedFilters            SavedFilter[]     @relation("SavedFilterOwner")
  backgroundJobsCreated   BackgroundJob[]   @relation("BackgroundJobCreator")
  contactNotes            ContactNote[]     @relation("ContactNoteAuthor")
  apiRequestLogs          ApiRequestLog[]

  @@unique([companyId, email])
  @@index([clerkId])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, role])
  @@index([scheduledDeletionAt])
  @@map("users")
}

// =============================================
// 📞 CALLS MODULE
// =============================================

model Call {
  id                  String        @id @default(uuid())
  
  // Tenant & User
  companyId           String        @map("company_id")
  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId              String        @map("user_id")
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Call Details
  phoneNumber         String        @map("phone_number")
  contactName         String?       @map("contact_name")
  direction           CallDirection
  status              CallStatus    @default(INITIATED)
  duration            Int           @default(0)
  
  // Twilio Integration
  twilioCallSid       String?       @unique @map("twilio_call_sid")
  twilioRecordingSid  String?       @map("twilio_recording_sid")
  recordingUrl        String?       @map("recording_url")
  
  // Transcription
  transcript          String?       @db.Text
  transcriptSegments  Json?         @map("transcript_segments")
  
  // AI Analysis
  summary             String?       @db.Text
  sentiment           Float?
  sentimentLabel      SentimentLabel?  @map("sentiment_label")
  keywords            String[]      @default([])
  actionItems         Json?         @map("action_items")
  
  // Organization
  tags                String[]      @default([])
  notes               String?       @db.Text
  metadata            Json?
  
  // Timestamps
  startedAt           DateTime?     @map("started_at")
  endedAt             DateTime?     @map("ended_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  aiSuggestions       AISuggestion[]
  callSummary         CallSummary?
  tagLinks            CallTag[]

  @@index([companyId])
  @@index([userId])
  @@index([companyId, status])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, sentiment])      // Sentiment analytics queries
  @@index([phoneNumber])
  @@index([twilioCallSid])
  @@map("calls")
}

// =============================================
// 💬 WHATSAPP MODULE
// =============================================

model WhatsappChat {
  id                  String        @id @default(uuid())
  
  // Tenant
  companyId           String        @map("company_id")
  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Assigned Agent (optional)
  userId              String?       @map("user_id")
  user                User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Customer Info
  customerPhone       String        @map("customer_phone")
  customerName        String?       @map("customer_name")
  customerAvatar      String?       @map("customer_avatar")
  
  // Chat Status
  status              ChatStatus    @default(OPEN)
  priority            ChatPriority  @default(NORMAL)
  unreadCount         Int           @default(0) @map("unread_count")
  
  // Last Message Preview
  lastMessageAt       DateTime?     @map("last_message_at")
  lastMessagePreview  String?       @map("last_message_preview")
  
  // Organization
  tags                String[]      @default([])
  metadata            Json?

  // SLA tracking (session 49)
  firstAgentReplyAt   DateTime?     @map("first_agent_reply_at")
  resolvedAt          DateTime?     @map("resolved_at")
  slaResponseBreached Boolean       @default(false) @map("sla_response_breached")
  slaResolutionBreached Boolean     @default(false) @map("sla_resolution_breached")
  slaBreachedAt       DateTime?     @map("sla_breached_at")

  // Timestamps
  archivedAt          DateTime?     @map("archived_at")
  deletedAt           DateTime?     @map("deleted_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  messages            WhatsappMessage[]
  aiSuggestions       AISuggestion[]
  tagLinks            ChatTag[]

  @@unique([companyId, customerPhone])
  @@index([companyId])
  @@index([userId])
  @@index([companyId, status])
  @@index([companyId, lastMessageAt(sort: Desc)])
  @@index([companyId, status, priority])
  @@map("whatsapp_chats")
}

model WhatsappMessage {
  id              String            @id @default(uuid())
  
  // Chat Relationship
  chatId          String            @map("chat_id")
  chat            WhatsappChat      @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // Message Details
  waMessageId     String?           @unique @map("wa_message_id")
  type            MessageType       @default(TEXT)
  direction       MessageDirection
  status          MessageStatus     @default(PENDING)
  
  // Content
  content         String            @db.Text
  mediaUrl        String?           @map("media_url")
  mediaType       String?           @map("media_type")
  mediaMimeType   String?           @map("media_mime_type")
  
  // AI Tracking
  aiSuggestionUsed Boolean          @default(false) @map("ai_suggestion_used")
  
  // Metadata
  metadata        Json?
  
  // Timestamps
  sentAt          DateTime?         @map("sent_at")
  deliveredAt     DateTime?         @map("delivered_at")
  readAt          DateTime?         @map("read_at")
  createdAt       DateTime          @default(now()) @map("created_at")

  @@index([chatId])
  @@index([chatId, createdAt(sort: Desc)])
  @@index([waMessageId])
  // Analytics: AI suggestion adoption metrics (analytics.service.getWhatsAppAnalytics)
  @@index([chatId, aiSuggestionUsed, createdAt(sort: Desc)])
  // Sender direction queries (e.g. count INCOMING for response-rate)
  @@index([chatId, direction, createdAt(sort: Desc)])
  @@map("whatsapp_messages")
}

// =============================================
// 🤖 AI SUGGESTIONS
// =============================================

model AISuggestion {
  id              String          @id @default(uuid())
  
  // Context - One of these will be set
  callId          String?         @map("call_id")
  call            Call?           @relation(fields: [callId], references: [id], onDelete: Cascade)
  chatId          String?         @map("chat_id")
  chat            WhatsappChat?   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  // Created by
  userId          String?         @map("user_id")
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Suggestion Content
  type            SuggestionType
  content         String          @db.Text
  confidence      Float           @default(0.8)
  
  // Context that generated the suggestion
  triggerText     String?         @db.Text @map("trigger_text")
  
  // Usage Tracking
  wasUsed         Boolean         @default(false) @map("was_used")
  usedAt          DateTime?       @map("used_at")
  
  // Feedback
  feedback        SuggestionFeedback? 
  feedbackNote    String?         @map("feedback_note")
  
  // AI Metadata
  model           String?
  promptTokens    Int?            @map("prompt_tokens")
  completionTokens Int?           @map("completion_tokens")
  latencyMs       Int?            @map("latency_ms")
  
  // Timestamps
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([callId])
  @@index([chatId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([callId, wasUsed])    // Analytics: suggestion adoption per call
  @@index([chatId, wasUsed])    // Analytics: suggestion adoption per chat
  @@map("ai_suggestions")
}

// =============================================
// 💳 BILLING MODULE
// =============================================

model Subscription {
  id                    String              @id @default(uuid())
  
  // Company
  companyId             String              @map("company_id")
  company               Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Stripe
  stripeSubscriptionId  String              @unique @map("stripe_subscription_id")
  stripePriceId         String              @map("stripe_price_id")
  stripeCustomerId      String?             @map("stripe_customer_id")

  // Subscription Details
  plan                  Plan
  status                SubscriptionStatus
  
  // Billing Period
  currentPeriodStart    DateTime            @map("current_period_start")
  currentPeriodEnd      DateTime            @map("current_period_end")
  
  // Trial
  trialStart            DateTime?           @map("trial_start")
  trialEnd              DateTime?           @map("trial_end")
  
  // Cancellation
  cancelAtPeriodEnd     Boolean             @default(false) @map("cancel_at_period_end")
  canceledAt            DateTime?           @map("canceled_at")
  cancelReason          String?             @map("cancel_reason")

  // Timestamps
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id                  String        @id @default(uuid())
  
  // Company
  companyId           String        @map("company_id")
  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Stripe
  stripeInvoiceId     String        @unique @map("stripe_invoice_id")
  stripeCustomerId    String?       @map("stripe_customer_id")
  
  // Invoice Details
  status              InvoiceStatus
  currency            String        @default("brl")
  amount              Int           @default(0)
  amountPaid          Int           @default(0) @map("amount_paid")
  
  // URLs
  hostedInvoiceUrl    String?       @map("hosted_invoice_url")
  pdfUrl              String?       @map("pdf_url")
  
  // Dates
  periodStart         DateTime?     @map("period_start")
  periodEnd           DateTime?     @map("period_end")
  dueDate             DateTime?     @map("due_date")
  paidAt              DateTime?     @map("paid_at")

  // Dunning (Sessão 42 — payment recovery)
  paymentAttempts     Int           @default(0) @map("payment_attempts")
  lastPaymentError    String?       @map("last_payment_error")
  nextDunningAt       DateTime?     @map("next_dunning_at")
  dunningStage        String?       @map("dunning_stage") // D1 | D3 | D7 | SUSPENDED

  // Timestamps
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([stripeInvoiceId])
  @@index([status])
  @@index([nextDunningAt]) // Dunning cron scans
  @@map("invoices")
}

// =============================================
// 🔔 NOTIFICATIONS
// =============================================

model Notification {
  id            String            @id @default(uuid())
  
  // Relationships
  companyId     String            @map("company_id")
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String            @map("user_id")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notification
  type          NotificationType
  title         String
  message       String            @db.Text
  data          Json?
  
  // Status
  read          Boolean           @default(false)
  readAt        DateTime?         @map("read_at")
  
  // Delivery
  channel       NotificationChannel @default(IN_APP)
  sentAt        DateTime?         @map("sent_at")

  // Timestamps
  createdAt     DateTime          @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([companyId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// =============================================
// 🔑 API KEYS
// =============================================

model ApiKey {
  id               String    @id @default(uuid())

  // Company
  companyId        String    @map("company_id")
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Key
  name             String
  keyHash          String    @unique @map("key_hash")
  keyPrefix        String    @map("key_prefix")

  // Permissions
  scopes           String[]  @default([])

  // Per-key rate limit (requests per minute). NULL = plan default.
  rateLimitPerMin  Int?      @map("rate_limit_per_min")

  // Who created it (nullable for legacy rows)
  createdById      String?   @map("created_by_id")
  createdBy        User?     @relation("ApiKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)

  // Status
  isActive         Boolean   @default(true) @map("is_active")
  expiresAt        DateTime? @map("expires_at")
  lastUsedAt       DateTime? @map("last_used_at")
  usageCount       Int       @default(0) @map("usage_count")

  // Timestamps
  createdAt        DateTime  @default(now()) @map("created_at")
  revokedAt        DateTime? @map("revoked_at")

  // Relations
  requestLogs      ApiRequestLog[]

  @@index([companyId])
  @@index([keyHash])
  @@index([companyId, isActive])
  @@map("api_keys")
}

// =============================================
// 📝 AUDIT LOG
// =============================================

model AuditLog {
  id            String    @id @default(uuid())
  
  // Context
  companyId     String    @map("company_id")
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String?   @map("user_id")
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Action
  action        AuditAction
  resource      String
  resourceId    String?   @map("resource_id")
  
  // Details
  description   String?
  oldValues     Json?     @map("old_values")
  newValues     Json?     @map("new_values")
  
  // Request Context
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  requestId     String?   @map("request_id")

  // Timestamp
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([companyId])
  @@index([userId])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([action])
  @@index([resource])
  @@map("audit_logs")
}

// =============================================
// 📋 ENUMS
// =============================================

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum CompanySize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  VENDOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
  CANCELED
}

enum SentimentLabel {
  VERY_POSITIVE
  POSITIVE
  NEUTRAL
  NEGATIVE
  VERY_NEGATIVE
}

enum ChatStatus {
  OPEN
  PENDING
  ACTIVE
  RESOLVED
  ARCHIVED
  BLOCKED
}

enum ChatPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  TEMPLATE
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum SuggestionType {
  GREETING
  OBJECTION_HANDLING
  CLOSING
  QUESTION
  INFORMATION
  FOLLOW_UP
  EMPATHY
  RAPPORT
  GENERAL
}

enum SuggestionFeedback {
  HELPFUL
  NOT_HELPFUL
  PARTIALLY_HELPFUL
}

// =============================================
// 🧑‍🏫 COACHING REPORTS (Session 44)
// =============================================
// Weekly AI coaching digest per vendor — aggregated metrics + GPT insights.
// Produced by cron Monday 07:00 BRT and emailed via Resend.
// =============================================

model CoachingReport {
  id              String   @id @default(uuid())

  // Tenant + Vendor
  companyId       String   @map("company_id")
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Period (ISO week boundaries, UTC)
  weekStart       DateTime @map("week_start")
  weekEnd         DateTime @map("week_end")

  // Aggregated metrics (schema-on-read JSON):
  //   {
  //     calls: { total, completed, missed, avgDuration, conversionRate },
  //     whatsapp: { chats, messagesSent, responseRateP50Minutes },
  //     ai: { suggestionsShown, suggestionsUsed, adoptionRate },
  //     sentiment: { positive, neutral, negative }
  //   }
  metrics         Json

  // LLM output
  insights        String[]  // 3-5 bullet-sized observations
  recommendations String[]  // 2-4 actionable suggestions
  provider        String    @default("openai")

  // Email delivery tracking
  emailSentAt     DateTime? @map("email_sent_at")
  emailError      String?   @map("email_error")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([userId, weekStart], name: "user_week_unique")
  @@index([companyId, weekStart])
  @@index([userId, weekStart])
  @@map("coaching_reports")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
  INCOMPLETE
  PAUSED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum NotificationType {
  SYSTEM
  CALL_STARTED
  CALL_ENDED
  NEW_MESSAGE
  AI_SUGGESTION
  SUBSCRIPTION_UPDATE
  BILLING_ALERT
  TEAM_UPDATE
  SLA_ALERT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  INVITE
  REVOKE
}

// =============================================
// 📞 CALL SUMMARY (Session 45)
// =============================================
// Persisted auto-summary produced after Call transcription completes.
// 1:1 with Call (unique callId). Generated by SummariesService and stored
// so it survives Redis TTL and is immediately available on UI load.
// =============================================

model CallSummary {
  id               String   @id @default(uuid())

  // 1:1 with Call
  callId           String   @unique @map("call_id")
  call             Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  // Redundant tenant filter (denormalised for query perf + tenant guards)
  companyId        String   @map("company_id")
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Summary payload (mirrors ConversationSummary shape from SummariesService)
  keyPoints        String[]                            // 3-8 bullet observations
  sentimentTimeline Json                               // [{ position: 0..1, sentiment: 'positive'|'neutral'|'negative' }]
  nextBestAction   String                              @db.Text

  // Provenance
  provider         String   @default("openai")         // openai | fallback:error | fallback:non-json
  contentHash      String   @map("content_hash")       // SHA-256 prefix of transcript (for staleness check)

  // Timestamps
  generatedAt      DateTime @default(now()) @map("generated_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([companyId, generatedAt(sort: Desc)])
  @@map("call_summaries")
}

// =============================================
// 🎯 TEAM GOALS (Session 45)
// =============================================
// Performance targets per vendor (or company-wide when userId is null).
// Managers set weekly/monthly goals; leaderboard shows progress vs target.
// =============================================

model TeamGoal {
  id             String         @id @default(uuid())

  // Tenant
  companyId      String         @map("company_id")
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Nullable: null = company-wide goal; set = per-vendor goal
  userId         String?        @map("user_id")
  user           User?          @relation("TeamGoalAssignee", fields: [userId], references: [id], onDelete: Cascade)

  // What to track
  metric         GoalMetric
  target         Int                                    // Numeric target (count or percentage 0-100)
  periodType     GoalPeriodType @map("period_type")

  // Period window (inclusive start, exclusive end — UTC)
  periodStart    DateTime       @map("period_start")
  periodEnd      DateTime       @map("period_end")

  // Who created it (audit + display)
  createdById    String         @map("created_by_id")
  createdBy      User           @relation("TeamGoalCreator", fields: [createdById], references: [id], onDelete: Restrict)

  // Timestamps
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // One active goal per (company, user|null, metric, periodStart)
  @@unique([companyId, userId, metric, periodStart], name: "goal_period_unique")
  @@index([companyId, periodStart])
  @@index([companyId, userId])
  @@index([companyId, metric, periodStart])
  @@map("team_goals")
}

enum GoalMetric {
  CALLS_TOTAL           // Total calls placed/received
  CALLS_COMPLETED       // Calls reaching COMPLETED status
  CONVERSION_RATE       // % completed / total
  AI_ADOPTION_RATE      // % AI suggestions used
  WHATSAPP_MESSAGES     // Outgoing WhatsApp messages
}

enum GoalPeriodType {
  WEEKLY
  MONTHLY
}

// =============================================
// 🔔 OUTBOUND WEBHOOKS (session 46)
// =============================================

model WebhookEndpoint {
  id            String           @id @default(uuid())
  companyId     String           @map("company_id")
  url           String
  description   String?
  secret        String           // HMAC SHA-256 secret
  events        WebhookEvent[]
  isActive      Boolean          @default(true) @map("is_active")
  createdById   String           @map("created_by_id")
  lastSuccessAt DateTime?        @map("last_success_at")
  lastFailureAt DateTime?        @map("last_failure_at")
  failureCount  Int              @default(0) @map("failure_count")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy     User             @relation("WebhookEndpointCreator", fields: [createdById], references: [id], onDelete: Restrict)
  deliveries    WebhookDelivery[]

  @@index([companyId, isActive])
  @@index([companyId, createdAt])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id               String                @id @default(uuid())
  endpointId       String                @map("endpoint_id")
  companyId        String                @map("company_id")
  event            WebhookEvent
  payload          Json
  status           WebhookDeliveryStatus @default(PENDING)
  attempts         Int                   @default(0)
  lastAttemptAt    DateTime?             @map("last_attempt_at")
  nextAttemptAt    DateTime?             @map("next_attempt_at")
  responseStatus   Int?                  @map("response_status")
  responseBody     String?               @map("response_body") @db.Text
  errorMessage     String?               @map("error_message") @db.Text
  deliveredAt      DateTime?             @map("delivered_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt

  endpoint         WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([endpointId, createdAt(sort: Desc)])
  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}

enum WebhookEvent {
  CALL_COMPLETED
  CHAT_MESSAGE_RECEIVED
  SUMMARY_READY
  COACHING_REPORT_CREATED
  SLA_BREACHED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCEEDED
  FAILED
  DEAD_LETTER
}

// =============================================
// 💬 REPLY TEMPLATES (session 46)
// =============================================

model ReplyTemplate {
  id          String                 @id @default(uuid())
  companyId   String                 @map("company_id")
  createdById String                 @map("created_by_id")
  name        String
  channel     ReplyTemplateChannel
  category    String?                // e.g. "objection", "greeting", "follow-up"
  content     String                 @db.Text
  variables   String[]               // variable keys allowed, e.g. ["customerName","product"]
  isActive    Boolean                @default(true) @map("is_active")
  usageCount  Int                    @default(0) @map("usage_count")
  lastUsedAt  DateTime?              @map("last_used_at")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation("ReplyTemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([companyId, name], name: "template_name_unique")
  @@index([companyId, channel, isActive])
  @@index([companyId, category])
  @@map("reply_templates")
}

enum ReplyTemplateChannel {
  CALL
  WHATSAPP
  BOTH
}

// =============================================
// 🏷️ CONVERSATION TAGS (session 47)
// =============================================
// Relational tag library (shared per tenant) for cross-channel classification.
// Coexists with legacy flat `Call.tags`/`WhatsappChat.tags` string arrays
// (kept for backward compat — new code should use join tables).

model ConversationTag {
  id          String     @id @default(uuid())
  companyId   String     @map("company_id")
  createdById String     @map("created_by_id")
  name        String
  color       String     @default("#6366F1") // indigo-500
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt

  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User       @relation("ConversationTagCreator", fields: [createdById], references: [id], onDelete: Restrict)

  callLinks   CallTag[]
  chatLinks   ChatTag[]

  @@unique([companyId, name], name: "tag_name_unique")
  @@index([companyId])
  @@map("conversation_tags")
}

model CallTag {
  callId      String          @map("call_id")
  tagId       String          @map("tag_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  call        Call            @relation(fields: [callId], references: [id], onDelete: Cascade)
  tag         ConversationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([callId, tagId])
  @@index([tagId])
  @@map("call_tags")
}

model ChatTag {
  chatId      String          @map("chat_id")
  tagId       String          @map("tag_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  chat        WhatsappChat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  tag         ConversationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([chatId, tagId])
  @@index([tagId])
  @@map("chat_tags")
}



// =============================================
// 🔔 NOTIFICATION PREFERENCES (session 48)
// =============================================
// Granular preferences per (user × type × channel).
// Replaces legacy coarse flags in Company.settings.notificationPreferences
// (kept for backward-read during migration).

model NotificationPreference {
  id              String               @id @default(uuid())
  userId          String               @map("user_id")
  companyId       String               @map("company_id")
  type            NotificationType
  channel         NotificationChannel
  enabled         Boolean              @default(true)

  // Quiet hours (user-local). HH:MM in 24h; null = disabled.
  quietHoursStart String?              @map("quiet_hours_start")
  quietHoursEnd   String?              @map("quiet_hours_end")
  timezone        String?              // IANA — defaults to user profile tz or company tz

  // Digest: bundle EMAIL notifications into a daily recap instead of real-time.
  digestMode      Boolean              @default(false) @map("digest_mode")

  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel], name: "user_type_channel_unique")
  @@index([companyId])
  @@index([userId, digestMode])
  @@map("notification_preferences")
}

// =============================================
// 🧭 SAVED FILTERS / SMART LISTS (session 48)
// =============================================
// User-saved (or shared) query presets for calls/chats.
// filterJson is Zod-validated on write. userId null = shared tenant-wide.

model SavedFilter {
  id          String         @id @default(uuid())
  companyId   String         @map("company_id")
  userId      String?        @map("user_id") // null = shared
  name        String
  resource    FilterResource
  filterJson  Json           @map("filter_json")
  isPinned    Boolean        @default(false) @map("is_pinned")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?          @relation("SavedFilterOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, resource])
  @@index([companyId, userId])
  @@index([companyId, isPinned])
  @@map("saved_filters")
}

enum FilterResource {
  CALL
  CHAT
}

// =============================================
// ⚙️ BACKGROUND JOBS (session 49)
// =============================================
// DB-backed async job queue. Worker claims pending jobs with `runAt <= NOW()`,
// processes with exponential backoff, fails to DEAD_LETTER after maxAttempts.

model BackgroundJob {
  id             String             @id @default(uuid())
  companyId      String             @map("company_id")
  createdById    String?            @map("created_by_id")
  type           BackgroundJobType
  status         BackgroundJobStatus @default(PENDING)
  payload        Json               @default("{}")
  result         Json?
  progress       Int                @default(0) // 0..100
  attempts       Int                @default(0)
  maxAttempts    Int                @default(5) @map("max_attempts")
  runAt          DateTime           @default(now()) @map("run_at")
  startedAt      DateTime?          @map("started_at")
  finishedAt     DateTime?          @map("finished_at")
  lastError      String?            @map("last_error") @db.Text
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt

  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy      User?              @relation("BackgroundJobCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([status, runAt])
  @@index([companyId, type, createdAt])
  @@map("background_jobs")
}

enum BackgroundJobType {
  REGENERATE_CALL_SUMMARIES
  RECOMPUTE_COACHING_REPORTS
  BULK_DELETE_CALLS
  BULK_TAG_CALLS
  BULK_ASSIGN_CHATS
  EXPORT_ANALYTICS
}

enum BackgroundJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTER
  CANCELED
}

// =============================================
// ⏱️ SLA POLICIES (session 49)
// =============================================
// Tenant-defined response/resolution time targets per ChatPriority.
// Breach monitor cron flags OPEN chats past the target and emits notification + webhook.

model SlaPolicy {
  id               String        @id @default(uuid())
  companyId        String        @map("company_id")
  name             String
  priority         ChatPriority
  responseMins     Int           @map("response_mins") // time to first agent reply
  resolutionMins   Int           @map("resolution_mins") // time to close
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt

  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, priority], name: "sla_company_priority_unique")
  @@index([companyId, isActive])
  @@map("sla_policies")
}

// =============================================
// 👥 CONTACTS / CUSTOMER 360 (session 50)
// =============================================
// Unified customer record keyed by E.164 phone per tenant.
// Auto-upserted on inbound call/whatsapp via events. Powers timeline + notes.

model Contact {
  id                  String        @id @default(uuid())
  companyId           String        @map("company_id")
  phone               String        // E.164 normalized
  name                String?
  email               String?
  timezone            String?
  metadata            Json          @default("{}")
  tags                String[]      @default([])
  firstSeenAt         DateTime      @default(now()) @map("first_seen_at")
  lastInteractionAt   DateTime?     @map("last_interaction_at")
  totalCalls          Int           @default(0) @map("total_calls")
  totalChats          Int           @default(0) @map("total_chats")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  notes               ContactNote[]
  csatResponses       CsatResponse[]

  @@unique([companyId, phone], name: "contact_phone_unique")
  @@index([companyId, lastInteractionAt])
  @@index([companyId, name])
  @@map("contacts")
}

model ContactNote {
  id          String    @id @default(uuid())
  contactId   String    @map("contact_id")
  authorId    String    @map("author_id")
  content     String    @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author      User      @relation("ContactNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@map("contact_notes")
}

// =============================================
// 🌟 CSAT SURVEYS (session 50)
// =============================================
// Per-tenant config triggers post-close surveys via WhatsApp/email with a
// signed token. Public submit endpoint captures score + optional comment.

model CsatSurveyConfig {
  id            String          @id @default(uuid())
  companyId     String          @map("company_id")
  trigger       CsatTrigger
  delayMinutes  Int             @default(5) @map("delay_minutes")
  channel       CsatChannel     @default(WHATSAPP)
  messageTpl    String          @db.Text @map("message_tpl")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, trigger], name: "csat_config_unique")
  @@index([companyId, isActive])
  @@map("csat_survey_configs")
}

model CsatResponse {
  id            String              @id @default(uuid())
  companyId     String              @map("company_id")
  contactId     String?             @map("contact_id")
  callId        String?             @map("call_id")
  chatId        String?             @map("chat_id")
  trigger       CsatTrigger
  channel       CsatChannel
  token         String              @unique
  score         Int?                // 1..5, null until responded
  comment       String?             @db.Text
  status        CsatResponseStatus  @default(SCHEDULED)
  scheduledFor  DateTime            @map("scheduled_for")
  sentAt        DateTime?           @map("sent_at")
  respondedAt   DateTime?           @map("responded_at")
  expiresAt     DateTime            @map("expires_at")
  lastError     String?             @db.Text @map("last_error")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([companyId, status, scheduledFor])
  @@index([companyId, respondedAt])
  @@index([status, scheduledFor])
  @@map("csat_responses")
}

enum CsatTrigger {
  CALL_END
  CHAT_CLOSE
}

enum CsatChannel {
  WHATSAPP
  EMAIL
}

enum CsatResponseStatus {
  SCHEDULED
  SENT
  RESPONDED
  EXPIRED
  FAILED
}

// =============================================
// 📤 SCHEDULED EXPORTS (session 51)
// =============================================
// Per-tenant recurring exports delivered by email. Cron tick evaluates
// nextRunAt, generates the file for resource+filters, emails recipients
// with a deep link, persists lastRunStatus/lastError/runCount.

model ScheduledExport {
  id             String                      @id @default(uuid())
  companyId      String                      @map("company_id")
  createdById    String?                     @map("created_by_id")
  name           String
  resource       ScheduledExportResource
  format         ScheduledExportFormat       @default(CSV)
  cronExpression String                      @map("cron_expression")
  timezone       String                      @default("America/Sao_Paulo")
  recipients     String[]
  filters        Json                        @default("{}")
  isActive       Boolean                     @default(true) @map("is_active")
  lastRunAt      DateTime?                   @map("last_run_at")
  lastRunStatus  ScheduledExportRunStatus?   @map("last_run_status")
  lastError      String?                     @db.Text @map("last_error")
  lastRowCount   Int?                        @map("last_row_count")
  runCount       Int                         @default(0) @map("run_count")
  nextRunAt      DateTime?                   @map("next_run_at")
  createdAt      DateTime                    @default(now()) @map("created_at")
  updatedAt      DateTime                    @updatedAt @map("updated_at")

  company        Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isActive])
  @@index([isActive, nextRunAt])
  @@map("scheduled_exports")
}

enum ScheduledExportResource {
  ANALYTICS_OVERVIEW
  CONTACTS
  AUDIT_LOGS
  CALLS
  WHATSAPP_CHATS
  CSAT_RESPONSES
}

enum ScheduledExportFormat {
  CSV
  JSON
}

enum ScheduledExportRunStatus {
  OK
  FAILED
}

// =============================================
// 🧹 RETENTION POLICIES (session 51)
// =============================================
// Per-tenant per-resource TTL. A cron tick purges rows older than
// retentionDays with bounded batch + per-policy error isolation. LGPD-
// aligned: audit logs have a minimum floor enforced at service layer.

model RetentionPolicy {
  id               String                @id @default(uuid())
  companyId        String                @map("company_id")
  resource         RetentionResource
  retentionDays    Int                   @map("retention_days")
  isActive         Boolean               @default(true) @map("is_active")
  lastRunAt        DateTime?             @map("last_run_at")
  lastDeletedCount Int?                  @map("last_deleted_count")
  lastError        String?               @db.Text @map("last_error")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  company          Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, resource], name: "retention_policy_unique")
  @@index([companyId, isActive])
  @@map("retention_policies")
}

enum RetentionResource {
  CALLS
  WHATSAPP_CHATS
  AUDIT_LOGS
  AI_SUGGESTIONS
  CSAT_RESPONSES
  NOTIFICATIONS
}

// =============================================
// 📊 API REQUEST LOGS (session 52)
// =============================================
// Per-tenant request audit trail for API observability + compliance.
// Written by a buffered interceptor (batch flush every 5s / 100 entries)
// to avoid adding latency to the hot path.

model ApiRequestLog {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  apiKeyId    String?  @map("api_key_id")
  userId      String?  @map("user_id")
  method      String   @db.VarChar(10)
  path        String   @db.VarChar(500)
  statusCode  Int      @map("status_code")
  latencyMs   Int      @map("latency_ms")
  requestId   String?  @map("request_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  apiKey      ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, apiKeyId, createdAt(sort: Desc)])
  @@index([companyId, statusCode, createdAt(sort: Desc)])
  @@index([companyId, path])
  @@map("api_request_logs")
}
